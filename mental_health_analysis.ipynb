  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-keyword",
   "metadata": {},
   "outputs": [],
   "source": [
    "keyword_stats = df_clean.groupby('status')[['has_suicidal_keyword', 'has_stress_keyword', 'has_help_keyword']].mean() * 100\n",
